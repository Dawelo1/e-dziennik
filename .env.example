# Django
DJANGO_SECRET_KEY=replace-me-with-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.twoja-domena.pl

# CORS / CSRF (comma-separated values)
DJANGO_CORS_ALLOWED_ORIGINS=https://app.twoja-domena.pl
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.twoja-domena.pl,https://api.twoja-domena.pl
# DJANGO_CORS_ALLOW_ALL_ORIGINS=false

# Database
# Local default (when DATABASE_URL is not set): sqlite db.sqlite3
# Example PostgreSQL URL:
DATABASE_URL=postgresql://user:password@host:5432/dbname
DJANGO_DB_CONN_MAX_AGE=60

# Channels / WebSocket
REDIS_URL=redis://host:6379/0

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=przedszkole@example.com
