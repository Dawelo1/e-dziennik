# Backend base URL used by the frontend app.
# Example production value: https://api.twoja-domena.pl
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional explicit websocket URL. If omitted, frontend derives WS URL
# from VITE_API_BASE_URL (http->ws, https->wss) and appends /ws/chat/.
# VITE_WS_CHAT_URL=ws://127.0.0.1:8000/ws/chat/
